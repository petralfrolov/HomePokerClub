# -----------------------------------------------------------------------------
# Home Poker Club - Environment Configuration Template
# Copy this file to '.env' and adjust variables to suit your environment.
# -----------------------------------------------------------------------------

# --- Database Config ---
# URL format: sqlite+aiosqlite:///relative/path/to/db or absolute paths.
# For production Docker container deployment, it's recommended to store data inside the persisted volume directory.
# DATABASE_URL=sqlite+aiosqlite:///backend/data/poker.db

# --- CORS Security Settings ---
# Comma-separated list of allowed origin hosts. Required if accessing the API from a different domain or port.
# For Docker Nginx deployment proxying to same-origin port 80, this is often not strictly required but useful for custom API clients.
# CORS_ORIGINS=http://poker.vgsoft.site,https://poker.vgsoft.site,http://localhost:5173,http://localhost:80
